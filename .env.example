# Base de données PostgreSQL
DATABASE_URL="postgresql://gleba:gleba@localhost:5432/gleba?schema=public"
POSTGRES_USER=gleba
POSTGRES_PASSWORD=gleba
POSTGRES_DB=gleba

# NextAuth.js (authentification)
NEXTAUTH_SECRET="generate-a-secret-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST=true

# Admin initial (pour seed-admin.ts)
ADMIN_EMAIL="admin@gleba.local"
ADMIN_PASSWORD="changeme"
ADMIN_NAME="Administrateur"

# Application
# NODE_ENV est forcé à "production" dans l'image Docker (Dockerfile).
# Mettre "development" uniquement pour `npm run dev` en local hors Docker.
NODE_ENV=production

# Email de notification feedback (laisser vide en self-host si vous lisez
# les retours via l'UI admin ; sinon mettre votre adresse de support)
FEEDBACK_EMAIL=

# SMTP (optionnel — pour envois feedback, reset password, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Ollama Cloud (assistant chat — optionnel, désactivé par défaut côté public)
OLLAMA_API_KEY=
OLLAMA_MODEL=nemotron-3-nano:30b
