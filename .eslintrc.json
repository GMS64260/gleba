{
  "extends": ["next/core-web-vitals", "next/typescript"],
  "rules": {
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/\\b(Variete|Varietes|Espece|Especes|Annee|Annees|Recolte|Recoltes|Categorie|Categories|Itineraire|Itineraires|Parametre|Parametres|Maraichage|Reference|References|Detail|Details|Necessaire|Necessaires|Pepiniere|Definir|Definit|Definissent|Plantees|Semees|Terminees|Sauvegardees|Numerote|Genere|Generee|Etape|Etat|Selectionner|Selection|Duree|Delai|Creer)\\b/]",
