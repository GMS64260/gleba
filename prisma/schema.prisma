// ============================================================
// PROMPT 17 — PRODUCTION LAITIÈRE & FROMAGES
// ============================================================

/// Collecte de lait — saisie biquotidienne par animal ou par lot.
model CollecteLait {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date            DateTime @map("date") // jour de la traite (sans heure)
  traite          String   @map("traite") // 'Matin' | 'Soir' | 'Unique'
  // L'un des deux doit être renseigné (validation applicative)
  animalId        Int?     @map("animal_id")
  animal          Animal?  @relation(fields: [animalId], references: [id], onDelete: SetNull)
  lotId           Int?     @map("lot_id")
  lot             LotAnimaux? @relation(fields: [lotId], references: [id], onDelete: SetNull)
  quantiteLitres  Decimal  @map("quantite_litres") @db.Decimal(10, 3)
  // Analyses laboratoire (optionnel — saisie périodique)
  mgGpl           Decimal? @map("mg_gpl") @db.Decimal(5, 2) // matière grasse g/L
  mpGpl           Decimal? @map("mp_gpl") @db.Decimal(5, 2) // matière protéique g/L
  cellulesParMl   Int?     @map("cellules_par_ml")          // numération cellulaire (×1000/mL)
  temperatureC    Decimal? @map("temperature_c") @db.Decimal(4, 1)
  // PROMPT 19 LOT B — lait écarté car animal en temps d'attente vétérinaire
  ecarteAttente   Boolean  @default(false) @map("ecarte_attente")
  notes           String?  @map("notes")
  // Affectation à un lot fromage (NULL = lait cru vendu ou non encore affecté)
  lotFromageId    String?  @map("lot_fromage_id")
  lotFromage      LotFromage? @relation(fields: [lotFromageId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([userId, date, traite, animalId, lotId], map: "uniq_collecte_traite")
  @@index([userId, date])
  @@index([animalId])
  @@index([lotId])
  @@index([lotFromageId])
  @@map("collectes_lait")
}

/// Lot de fabrication fromage (paquet hygiène : traçabilité descendante).
model LotFromage {
  id                  String   @id @default(cuid())
  userId              String   @map("user_id")
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  numeroLot           String   @map("numero_lot") // L-2026-W20-01
  dateFabrication     DateTime @map("date_fabrication")
  typeFromage         String   @map("type_fromage") // 'Frais','Tomme','Crottin','Brique',...
  volumeLaitUtiliseL  Decimal  @map("volume_lait_utilise_l") @db.Decimal(10, 2)
  nbPieces            Int      @map("nb_pieces")
  poidsTotalKg        Decimal  @map("poids_total_kg") @db.Decimal(10, 3)
  dluo                DateTime? @map("dluo")
  // Snapshot du statut Bio majoritaire (cf PROMPT 12)
  statutBioSnapshot   String?  @map("statut_bio_snapshot") // 'AB' | 'C1' | 'C2' | 'C3' | 'Conventionnel'
  // Mention sur étiquette : 'cru' | 'thermise' | 'pasteurise'
  traitementThermique String   @default("cru") @map("traitement_thermique")
  // Allergènes additionnels au-delà du lait (texte libre)
  allergenes          String?  @map("allergenes")
  // N° d'agrément sanitaire éventuel (CE FR XX-XXX-XXX)
  numeroAgrement      String?  @map("numero_agrement")
  notes               String?  @map("notes")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  collectes           CollecteLait[]
  ventesProduit       VenteProduit[]

  @@unique([userId, numeroLot])
  @@index([userId, dateFabrication])
  @@map("lots_fromage")
}

// ============================================================
// MODULE COMPTABILITÉ
// ============================================================

/// Ventes manuelles (légumes, services, etc. - non trackées ailleurs)
// ============================================================
// COMPTABILITÉ - CLIENTS & FACTURES
// ============================================================

/// Clients (acheteurs)
model Client {
  id                 Int      @id @default(autoincrement())
  userId             String   @map("user_id")
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nom                String   @map("nom")
  type               String   @default("particulier") @map("type") // "particulier", "professionnel", "association", "amap"
  email              String?  @map("email")
  telephone          String?  @map("telephone")
  adresse            String?  @map("adresse")
  ville              String?  @map("ville")
  codePostal         String?  @map("code_postal")
  pays               String?  @default("France") @map("pays")
  siret              String?  @map("siret") // Pour professionnels
  tvaIntra           String?  @map("tva_intra") // Numéro TVA intracommunautaire
  conditionsPaiement Int?     @default(0) @map("conditions_paiement") // Délai paiement en jours (0 = comptant)
  exonererTVA        Boolean  @default(false) @map("exonerer_tva") // Client exonéré de TVA
  notes              String?  @map("notes")
  actif              Boolean  @default(true) @map("actif")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // Relations
  ventesManuelles VenteManuelle[]
  factures        Facture[]

  @@index([userId])
  @@index([nom])
  @@map("clients")
}

/// Factures émises
model Facture {
  id              Int       @id @default(autoincrement())
  userId          String    @map("user_id")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  numero          String    @map("numero") // F-2026-0001
  type            String    @default("facture") @map("type") // "facture", "avoir", "acompte"
  clientId        Int?      @map("client_id")
  client          Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientNom       String    @map("client_nom") // Copie pour archivage
  clientAdresse   String?   @map("client_adresse")
  date            DateTime  @default(now()) @map("date")
  dateEcheance    DateTime? @map("date_echeance")
  objet           String?   @map("objet")
  // Montants
  totalHT         Float     @map("total_ht")
  totalTVA        Float     @default(0) @map("total_tva")
  totalTTC        Float     @map("total_ttc")
  // PROMPT 14C — totaux par taux de TVA (JSON: { "5.5": {ht: 100, tva: 5.5}, "20": {...} })
  totauxParTauxTva Json?    @map("totaux_par_taux_tva")
  // Statut
  statut          String    @default("emise") @map("statut") // "brouillon", "emise", "payee", "annulee"
  datePaiement    DateTime? @map("date_paiement")
  modePaiement    String?   @map("mode_paiement") // "especes", "cheque", "cb", "virement"
  // Référence avoir
  factureOrigineId Int?     @map("facture_origine_id") // Pour les avoirs
  // PROMPT 14C — Conditions, mentions spécifiques (cases cochables)
  conditionsPaiement   String?  @map("conditions_paiement") // texte libre
  mentionsSpecifiques  String[] @default([]) @map("mentions_specifiques") // ['293b', 'escompte', 'penalites', 'indemnite-40', 'ab']
  // PROMPT 14C — Snapshot émetteur figé à l'émission (immuable pour archivage légal)
  emetteurSnapshot     Json?    @map("emetteur_snapshot")
  notes           String?   @map("notes")
  mentionsLegales String?   @map("mentions_legales")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  lignes           LigneFacture[]
  ventesProduits   VenteProduit[]   @relation("VenteProduitFacture")
  abattages        Abattage[]       @relation("AbattageFacture")
  recoltesArbres   RecolteArbre[]   @relation("RecolteArbreFacture")
  productionsBois  ProductionBois[] @relation("ProductionBoisFacture")
  commandesBoutique CommandeBoutique[] @relation("CommandeFacture")

  @@unique([userId, numero])
  @@index([userId])
  @@index([clientId])
  @@index([date])
  @@index([statut])
  @@map("factures")
}

/// Lignes de facture
model LigneFacture {
  id           Int     @id @default(autoincrement())
  factureId    Int     @map("facture_id")
  facture      Facture @relation(fields: [factureId], references: [id], onDelete: Cascade)
  ordre        Int     @default(0) @map("ordre")
  description  String  @map("description")
  quantite     Float   @map("quantite")
  unite        String  @default("unité") @map("unite")
  prixUnitaire Float   @map("prix_unitaire") // HT
  tauxTVA      Float   @default(5.5) @map("taux_tva") // 5.5, 10, 20
  montantHT    Float   @map("montant_ht")
  montantTVA   Float   @map("montant_tva")
  montantTTC   Float   @map("montant_ttc")
  // PROMPT 12 — Statut Bio de la ligne (NULL = non renseigné).
  statutBio    String? @map("statut_bio") // Conventionnel | C1 | C2 | C3 | AB

  @@index([factureId])
  @@index([statutBio])
  @@map("lignes_factures")
}

// ============================================================
// COMPTABILITÉ - VENTES & DÉPENSES MANUELLES
// ============================================================

model VenteManuelle {
  id           Int      @id @default(autoincrement())
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date         DateTime @default(now()) @map("date")
  categorie    String   @map("categorie") // "legumes", "fruits", "transformation", "service", "autre"
  description  String   @map("description")
  quantite     Float?   @map("quantite")
  unite        String?  @map("unite") // kg, unite, heure
  prixUnitaire Float?   @map("prix_unitaire")
  // Montants avec TVA
  tauxTVA      Float    @default(5.5) @map("taux_tva") // 5.5%, 10%, 20%
  montantHT    Float?   @map("montant_ht")
  montantTVA   Float?   @map("montant_tva")
  montant      Float    @map("montant") // Total TTC en €
  // PROMPT 15A — Comptabilité enrichie
  journal      String   @default("VE") @map("journal") // VE, AC, BQ, CA, OD
  modeReglement String? @map("mode_reglement") // Espèces, Chèque, Virement, CB, Prélèvement, À crédit
  numeroPiece  String?  @map("numero_piece")
  pjUrl        String?  @map("pj_url") // pièce justificative scannée
  tvaInferee   Boolean  @default(false) @map("tva_inferee") // true si taux dérivé en migration
  // Client
  clientId     Int?     @map("client_id")
  client       Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientNom    String?  @map("client_nom") // Nom client (si pas de fiche client)
  module       String?  @map("module") // "potager", "verger", "elevage", "general"
  paye         Boolean  @default(true) @map("paye")
  // Traçabilité auto-compta
  sourceType   String?  @map("source_type") // "recolte", "recolte_arbre", "vente_produit", "abattage", "intervention"
  sourceId     Int?     @map("source_id")
  auto         Boolean  @default(false) @map("auto") // true = généré automatiquement
  notes        String?  @map("notes")
  createdAt    DateTime @default(now()) @map("created_at")

  commandesBoutique CommandeBoutique[] @relation("CommandeVente")

  @@index([userId])
  @@index([clientId])
  @@index([date])
  @@index([categorie])
  @@index([sourceType, sourceId])
  @@map("ventes_manuelles")
}

/// Dépenses manuelles (matériel, carburant, etc. - non trackées ailleurs)
model DepenseManuelle {
  id             Int      @id @default(autoincrement())
  userId         String   @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           DateTime @default(now()) @map("date")
  categorie      String   @map("categorie") // "materiel", "carburant", "main_oeuvre", "abonnement", "autre"
  description    String   @map("description")
  // Montants avec TVA
  tauxTVA        Float    @default(20) @map("taux_tva") // 5.5%, 10%, 20%
  montantHT      Float?   @map("montant_ht")
  montantTVA     Float?   @map("montant_tva") // TVA déductible
  montant        Float    @map("montant") // Total TTC en €
  // PROMPT 15A — Comptabilité enrichie
  journal        String   @default("AC") @map("journal") // VE, AC, BQ, CA, OD
  modeReglement  String?  @map("mode_reglement")
  numeroPiece    String?  @map("numero_piece")
  pjUrl          String?  @map("pj_url")
  tvaInferee     Boolean  @default(false) @map("tva_inferee")
  module         String?  @map("module") // "potager", "verger", "elevage", "general"
  // Fournisseur
  fournisseurId  String?  @map("fournisseur_id")
  fournisseurNom String?  @map("fournisseur_nom") // Nom fournisseur (si pas de fiche)
  refFacture     String?  @map("ref_facture") // Référence facture fournisseur
  paye           Boolean  @default(true) @map("paye")
  dateEcheance   DateTime? @map("date_echeance")
  // Traçabilité auto-compta
  sourceType     String?  @map("source_type") // "intervention", "consommation_aliment", "achat_animal"
  sourceId       Int?     @map("source_id")
  auto           Boolean  @default(false) @map("auto") // true = généré automatiquement
  notes          String?  @map("notes")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([fournisseurId])
  @@index([date])
  @@index([categorie])
  @@index([sourceType, sourceId])
  @@map("depenses_manuelles")
}

