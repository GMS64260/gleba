// ============================================================
// MODULE INTERVENTIONS & TRAÇABILITÉ
// ============================================================

/// Interventions terrain (opérations culturales)
model Intervention {
  id              Int       @id @default(autoincrement())
  userId          String    @map("user_id")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  date            DateTime  @default(now()) @map("date")
  type            String    @map("type") // "semis", "plantation", "desherbage", "binage", "paillage", "traitement_phyto", "fertilisation", "recolte", "taille", "arrosage", "tuteurage", "autre"
  // Liens vers les objets concernés
  cultureId       Int?      @map("culture_id")
  plancheId       String?   @map("planche_id")
  arbreId         Int?      @map("arbre_id")
  // Détails de l'intervention
  description     String?   @map("description")
  dureeMinutes    Int?      @map("duree_minutes") // Temps passé
  nbPersonnes     Int?      @default(1) @map("nb_personnes")
  coutMainOeuvre  Float?    @map("cout_main_oeuvre") // € main d'œuvre
  coutTotal       Float?    @map("cout_total") // € total (main d'œuvre + intrants)
  // Planification
  datePrevue      DateTime? @map("date_prevue")
  fait            Boolean   @default(true) @map("fait")
  // Traitement phytosanitaire (réglementaire)
  produitPhyto    String?   @map("produit_phyto") // Nom commercial
  numAMM          String?   @map("num_amm") // Numéro AMM (Autorisation de Mise sur le Marché)
  cibleTraitement String?   @map("cible_traitement") // Ravageur/maladie ciblé
  doseAppliquee   Float?    @map("dose_appliquee") // Dose utilisée
  uniteDose       String?   @map("unite_dose") // "L/ha", "kg/ha", "g/L"
  surfaceTraitee  Float?    @map("surface_traitee") // m² ou ha
  dar             Int?      @map("dar") // Délai Avant Récolte (jours)
  delaiReentree   Int?      @map("delai_reentree") // Heures avant réentrée
  conditionsMeteo String?   @map("conditions_meteo") // Conditions météo lors du traitement (texte libre, déprécié)
  // PROMPT 11 LOT A — FK vers le référentiel ProduitPhyto. Le champ TEXT
  // `produitPhyto` ci-dessus est conservé pour les saisies historiques.
  produitPhytoId  String?         @map("produit_phyto_id")
  produitPhytoRef ProduitPhyto?   @relation(fields: [produitPhytoId], references: [id], onDelete: SetNull)
  // PROMPT 11 LOT A — Action sans produit (taille sanitaire, désherbage manuel, etc.)
  geste           String?         @map("geste")
  // PROMPT 11 LOT B — Champs réglementaires détaillés (Arrêté 16 juin 2009).
  volumeBouillieLHa  Float?       @map("volume_bouillie_l_ha")
  temperatureC       Float?       @map("temperature_c")
  ventKmh            Float?       @map("vent_kmh")
  hygrometriePct     Int?         @map("hygrometrie_pct")
  operateurId        String?      @map("operateur_id")
  operateur          User?        @relation("InterventionOperateur", fields: [operateurId], references: [id], onDelete: SetNull)
  certiphytoNum      String?      @map("certiphyto_num")       // snapshot
  certiphytoValidite DateTime?    @map("certiphyto_validite")  // snapshot
  justification      String?      @map("justification")
  observationLieeId  Int?         @map("observation_liee_id")
  observationLiee    ObservationSante? @relation("InterventionObservation", fields: [observationLieeId], references: [id], onDelete: SetNull)
  // Intrants consommés
  intrantNom      String?   @map("intrant_nom") // Nom de l'intrant utilisé
  intrantQuantite Float?    @map("intrant_quantite")
  intrantUnite    String?   @map("intrant_unite") // kg, L, g, unités
  intrantCout     Float?    @map("intrant_cout") // Coût de l'intrant
  intrantNumLot   String?   @map("intrant_num_lot") // Numéro de lot (traçabilité)
  notes           String?   @map("notes")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@index([userId, date])
  @@index([cultureId])
  @@index([plancheId])
  @@index([arbreId])
  @@index([type])
  @@index([fait])
  @@index([produitPhytoId])
  @@index([operateurId])
  @@index([observationLieeId])
  @@map("interventions")
}

/// PROMPT 11 LOT A — Référentiel des produits phytosanitaires.
/// Classification réglementaire (E-Phy + AB / PNPP / biocontrôle) pour produire
/// un registre phyto recevable par certificateur (Agence Bio, HVE, DRAAF).
model ProduitPhyto {
  id               String   @id @default(cuid())
  nomCommercial    String   @unique @map("nom_commercial")
  substanceActive  String   @map("substance_active")
  amm              String?  @map("amm")             // numéro E-Phy
  classification   String   @map("classification")  // cf CHECK SQL
  autoriseAB       Boolean  @default(false) @map("autorise_ab")
  zntAquatiqueM    Int?     @map("znt_aquatique_m") // 5 / 20 / 50
  darJours         Int?     @map("dar_jours")
  doseHomologuee   String?  @map("dose_homologuee")
  plafondAB        String?  @map("plafond_ab")      // ex: "Cu: 28 kg/ha/7 ans"
  notes            String?  @map("notes")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  interventions    Intervention[]

  @@index([classification])
  @@index([autoriseAB])
  @@map("produits_phyto")
}

// ============================================================
// CHAT IA (Assistant Ollama)
// ============================================================

/// Conversations de chat IA
model Conversation {
  id        String        @id @default(cuid())
  userId    String        @map("user_id")
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  messages  ChatMessage[]

  @@index([userId])
  @@index([updatedAt])
  @@map("conversations")
}

/// Messages de chat IA
model ChatMessage {
  id             Int          @id @default(autoincrement())
  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String       // "user", "assistant", "tool"
  content        String       @db.Text
  toolCalls      Json?        @map("tool_calls")
  toolResults    Json?        @map("tool_results")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([conversationId])
  @@map("chat_messages")
}

// ============================================================
// MODULE MÉTÉO
// ============================================================

/// Cache des données météo par coordonnées et date
model MeteoCache {
  id              Int      @id @default(autoincrement())
  lat             Float    @map("lat")
  lng             Float    @map("lng")
  date            DateTime @map("date") @db.Date
  source          String   @default("open-meteo") @map("source") // "open-meteo", "station_perso"
  // Températures (°C)
  tempMin         Float?   @map("temp_min")
  tempMax         Float?   @map("temp_max")
  tempMoy         Float?   @map("temp_moy")
  // Précipitations (mm)
  precipitation   Float?   @map("precipitation")
  // Évapotranspiration de référence (mm)
  et0             Float?   @map("et0")
  // Rayonnement solaire (MJ/m²)
  radiation       Float?   @map("radiation")
  // Ensoleillement (heures)
  sunshine        Float?   @map("sunshine_hours")
  // Humidité (%)
  humidityMin     Float?   @map("humidity_min")
  humidityMax     Float?   @map("humidity_max")
  // Vent (km/h)
  windSpeedMax    Float?   @map("wind_speed_max")
  // Données brutes JSON (pour extensions futures)
  rawData         Json?    @map("raw_data")
  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([lat, lng, date, source])
  @@index([lat, lng])
  @@index([date])
  @@map("meteo_cache")
}

/// Stations météo personnelles des utilisateurs
model StationMeteo {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nom         String   @map("nom")
  provider    String   @map("provider") // "ecowitt", "wunderground", "netatmo"
  stationId   String   @map("station_id")
  apiKey      String?  @map("api_key")
  appKey      String?  @map("app_key") // Ecowitt app key
  lat         Float?   @map("lat")
  lng         Float?   @map("lng")
  active      Boolean  @default(true) @map("active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("stations_meteo")
}

// ============================================================
// MODULE BOUTIQUE EN LIGNE - VITRINE PUBLIQUE
// ============================================================

/// Boutique en ligne d'un utilisateur (vitrine publique personnalisée)
/// Accessible à /boutique/[slug]
model Boutique {
  id              String    @id @default(cuid())
  userId          String    @unique @map("user_id")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug            String    @unique // ex: "ferme-du-bois"
  nom             String    @map("nom") // Nom commercial affiché
  description     String?   @map("description") // Description longue
  descCourte      String?   @map("desc_courte") // Pour SEO / meta
  // Personnalisation visuelle
  logoUrl         String?   @map("logo_url")
  banniereUrl     String?   @map("banniere_url")
  couleurPrimaire String    @default("#0d9488") @map("couleur_primaire") // teal-600
  couleurSecondaire String  @default("#f59e0b") @map("couleur_secondaire") // amber-500
  // Contact
  email           String?   @map("email")
  telephone       String?   @map("telephone")
  adresse         String?   @map("adresse")
  ville           String?   @map("ville")
  codePostal      String?   @map("code_postal")
  // Infos vente
  horairesOuverture String? @map("horaires_ouverture") // texte libre multi-lignes
  modesPaiement   String?   @map("modes_paiement") // ex: "Espèces, chèque, CB"
  modesLivraison  String?   @map("modes_livraison") // ex: "Retrait à la ferme, marché du samedi"
  conditionsVente String?   @map("conditions_vente") // texte libre
  // Réseaux sociaux
  facebookUrl     String?   @map("facebook_url")
  instagramUrl    String?   @map("instagram_url")
  siteWebUrl      String?   @map("site_web_url")
  // Statut
  active          Boolean   @default(false) @map("active") // Visible publiquement ?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  produits        ProduitBoutique[]
  commandes       CommandeBoutique[]

  @@index([slug])
  @@index([active])
  @@map("boutiques")
}

/// Produit présenté dans la boutique
model ProduitBoutique {
  id              Int       @id @default(autoincrement())
  userId          String    @map("user_id")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  boutiqueId      String    @map("boutique_id")
  boutique        Boutique  @relation(fields: [boutiqueId], references: [id], onDelete: Cascade)
  nom             String    @map("nom")
  description     String?   @map("description")
  photoUrl        String?   @map("photo_url")
  prix            Float     @map("prix") // prix TTC
  unite           String    @default("pièce") @map("unite") // "kg", "pièce", "botte", "panier"
  stockDispo      Float?    @map("stock_dispo") // null = illimité, sinon décrémenté à chaque commande
  categorie       String?   @map("categorie") // "legumes", "fruits", "transformations", "viande", "oeufs", "miel", "autre"
  ordre           Int       @default(0) @map("ordre") // tri d'affichage
  actif           Boolean   @default(true) @map("actif")
  // PROMPT 12 — Statut Bio du produit (propagé depuis le lot de récolte source).
  statutBio       String?   @map("statut_bio") // Conventionnel | C1 | C2 | C3 | AB
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  lignesCommande  LigneCommandeBoutique[]

  @@index([userId])
  @@index([boutiqueId])
  @@index([actif])
  @@index([categorie])
  @@index([statutBio])
  @@map("produits_boutique")
}

/// Commande passée par un client via la boutique en ligne
model CommandeBoutique {
  id              Int       @id @default(autoincrement())
  userId          String    @map("user_id") // producteur
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  boutiqueId      String    @map("boutique_id")
  boutique        Boutique  @relation(fields: [boutiqueId], references: [id], onDelete: Cascade)
  // Numéro lisible (ex: CMD-2026-0001)
  numero          String    @unique @map("numero")
  // Client
  clientNom       String    @map("client_nom")
  clientEmail     String    @map("client_email")
  clientTelephone String?   @map("client_telephone")
  clientAdresse   String?   @map("client_adresse")
  // Détails commande
  total           Float     @map("total")
  modeLivraison   String?   @map("mode_livraison") // libellé libre
  dateRetraitSouhaitee DateTime? @map("date_retrait_souhaitee")
  notesClient     String?   @map("notes_client")
  notesPrivees    String?   @map("notes_privees")
  // Workflow
  statut          String    @default("nouveau") @map("statut") // "nouveau", "confirmee", "prete", "livree", "annulee"
  // PROMPT 16 LOT B — Câblage paiement / compta.
  paiementStatut    String    @default("En attente") @map("paiement_statut") // En attente | Confirmé | Annulé | Remboursé
  paiementProvider  String?   @map("paiement_provider")                       // Stripe | SumUp | Manuel | Virement
  paiementRef       String?   @map("paiement_ref")                            // ID transaction provider
  venteManuelleId   Int?      @map("vente_manuelle_id")
  venteManuelle     VenteManuelle? @relation("CommandeVente", fields: [venteManuelleId], references: [id], onDelete: SetNull)
  factureId         Int?      @map("facture_id")
  facture           Facture?  @relation("CommandeFacture", fields: [factureId], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  lignes          LigneCommandeBoutique[]

  @@index([userId])
  @@index([boutiqueId])
  @@index([statut])
  @@index([paiementStatut])
  @@index([venteManuelleId])
  @@index([factureId])
  @@index([createdAt])
  @@map("commandes_boutique")
}

/// Ligne d'une commande boutique
model LigneCommandeBoutique {
  id              Int       @id @default(autoincrement())
  commandeId      Int       @map("commande_id")
  commande        CommandeBoutique @relation(fields: [commandeId], references: [id], onDelete: Cascade)
  produitId       Int?      @map("produit_id")
  produit         ProduitBoutique? @relation(fields: [produitId], references: [id], onDelete: SetNull)
  nom             String    @map("nom") // snapshot du nom au moment de la commande
  prixUnitaire    Float     @map("prix_unitaire")
  unite           String    @map("unite")
  quantite        Float     @map("quantite")
  total           Float     @map("total")

  @@index([commandeId])
  @@index([produitId])
  @@map("lignes_commande_boutique")
}

/// Préférences utilisateur (clé/valeur, extensible)
/// Utilisé notamment pour : modulesActifs (JSON array des modules visibles)
model UserPreference {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  key       String   @map("key") // ex: "modulesActifs", "theme", "langue"
  value     String   @map("value") // valeur (JSON sérialisé si complexe)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, key])
  @@index([userId])
  @@map("user_preferences")
}

// ============================================================
// PROMPT 14 — IDENTITÉ LÉGALE & NUMÉROTATION FACTURES
// ============================================================

/// Identité légale de l'exploitation (1 par utilisateur).
/// Sert d'émetteur sur factures, FEC, déclarations TVA, etc.
model Exploitation {
  id                  String   @id @default(cuid())
  userId              String   @unique @map("user_id")
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Identité
  raisonSociale       String   @map("raison_sociale")
  formeJuridique      String   @map("forme_juridique") // 'EI','GAEC','SARL','EARL','SCEA','SCIC','autre'
  siret               String   @map("siret") // 14 chiffres, validation Luhn
  siren               String   @map("siren") // 9 chiffres, dérivé du SIRET
  numeroTvaIntracom   String?  @map("numero_tva_intracom") // FR + clé + SIREN
  // Fiscalité
  regimeFiscal        String   @map("regime_fiscal") // 'micro-BA','reel-simplifie','reel-normal'
  regimeTva           String   @map("regime_tva") // 'franchise-293b','reel-simplifie','reel-normal'
  // Adresse siège
  adresseSiege        String   @map("adresse_siege")
  codePostal          String   @map("code_postal")
  ville               String   @map("ville")
  pays                String   @default("France") @map("pays")
  // Contact
  emailContact        String   @map("email_contact")
  telContact          String?  @map("tel_contact")
  // Optionnels
  capitalSocial       Decimal? @map("capital_social") @db.Decimal(12, 2)
  rib                 String?  @map("rib") // IBAN affiché sur facture
  bic                 String?  @map("bic")
  banqueNom           String?  @map("banque_nom")
  logoUrl             String?  @map("logo_url")
  // Certification AB (optionnelle)
  certifBioOrganisme  String?  @map("certif_bio_organisme") // ex "Ecocert FR-BIO-01"
  // Mentions facture (par défaut, peuvent être surchargées)
  tauxPenalitesRetard String?  @map("taux_penalites_retard") // ex "3 × taux légal"
  indemniteRecouvrement Decimal @default(40) @map("indemnite_recouvrement") @db.Decimal(10, 2) // €
  tauxEscompte        String?  @map("taux_escompte") // ex "néant" ou "1%"

  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("exploitations")
}

/// Séquence de numérotation continue par exercice et par type de pièce.
/// Garantit l'absence de saut (obligation art. 242 nonies A CGI).
model SequenceFacture {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercice      Int      @map("exercice") // ex 2026
  type          String   @map("type") // 'FACTURE' | 'AVOIR' | 'DEVIS'
  prochainNum   Int      @default(1) @map("prochain_num")
  prefixe       String   @map("prefixe") // 'F-2026-' | 'AV-2026-' | 'D-2026-'
  format        String   @default("%04d") @map("format") // padding
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([userId, exercice, type])
  @@index([userId])
  @@map("sequences_facture")
}
