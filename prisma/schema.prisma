// Gleba - Schéma Prisma
// Migré depuis SQLite (Qt) vers PostgreSQL
// Voir ANALYSIS.md pour la documentation complète

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTHENTIFICATION
// ============================================================

enum Role {
  ADMIN
  USER
}

enum CoucheActivite {
  MARAICHAGE
  VERGER
  ELEVAGE
  PATURAGE
}

/// Utilisateurs de l'application
model User {
  id                String    @id @default(cuid())
  email             String    @unique
  password          String    // bcrypt hash
  name              String?
  role              Role      @default(USER)
  active            Boolean   @default(true)
  emailVerified     Boolean   @default(false) @map("email_verified")
  emailVerifyToken  String?   @unique @map("email_verify_token")
  emailVerifyExpires DateTime? @map("email_verify_expires")
  resetPasswordToken String?  @unique @map("reset_password_token")
  resetPasswordExpires DateTime? @map("reset_password_expires")
  apiToken          String?   @unique @map("api_token")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // NextAuth sessions
  sessions      Session[]

  // Relations avec données utilisateur
  planches      Planche[]
  cultures      Culture[]
  recoltes      Recolte[]
  consommations Consommation[]
  irrigationsPlanifiees IrrigationPlanifiee[]
  fertilisations Fertilisation[]
  objetsJardin  ObjetJardin[]
  parcellesGeo  ParcelleGeo[]
  analysesSol   AnalyseSol[]
  notes         Note[]
  arbres        Arbre[]

  // Relations module arbres
  recoltesArbres    RecolteArbre[]
  productionsBois   ProductionBois[]
  operationsArbres  OperationArbre[]

  // Relations module élevage
  animaux               Animal[]
  lotsAnimaux           LotAnimaux[]
  productionsOeufs      ProductionOeuf[]
  ventesProduits        VenteProduit[]
  abattages             Abattage[]
  consommationsAliments ConsommationAliment[]
  soinsAnimaux          SoinAnimal[]
  naissancesAnimales    NaissanceAnimale[]
  // PROMPT 17 — production laitière
  collectesLait         CollecteLait[]
  lotsFromage           LotFromage[]

  // Relations module comptabilité
  ventesManuelles       VenteManuelle[]
  depensesManuelles     DepenseManuelle[]
  clients               Client[]
  facturesEmises        Facture[]

  // Relations stocks per-user (multi-tenancy)
  userStockVarietes     UserStockVariete[]
  userStockFertilisants UserStockFertilisant[]
  userStockAliments     UserStockAliment[]
  userStockEspeces      UserStockEspece[]

  // Relations interventions & traçabilité
  interventions         Intervention[]
  // PROMPT 11 — Interventions où ce user est l'opérateur (≠ propriétaire de la fiche).
  interventionsOperateur Intervention[] @relation("InterventionOperateur")
  // PROMPT 11 — Certiphyto (snapshot copié dans chaque Intervention pour traçabilité).
  certiphytoNum         String?       @map("certiphyto_num")
  certiphytoValidite    DateTime?     @map("certiphyto_validite")

  // Relations chat IA
  conversations         Conversation[]

  // Relations module verger enrichi
  zonesVerger           ZoneVerger[]
  observationsSante     ObservationSante[]
  campagnesPlantation   CampagnePlantation[]
  etapesCampagne        EtapeCampagne[]
  observationsCampagne  ObservationCampagne[]

  // Relations module météo
  stationsMeteo         StationMeteo[]

  // Logs de connexion
  loginLogs             LoginLog[]

  // Feedback
  feedbackTokens        FeedbackToken[]
  feedbackResponses     FeedbackResponse[]

  // Préférences (modules visibles, etc.)
  preferences           UserPreference[]

  // Boutique en ligne (1 par utilisateur)
  boutique              Boutique?
  produitsBoutique      ProduitBoutique[]
  commandesBoutique     CommandeBoutique[]

  // PROMPT 14 — Identité légale de l'exploitation (SIRET, TVA, régime, etc.)
  exploitation          Exploitation?
  // PROMPT 14 — Séquences de numérotation factures/avoirs/devis par exercice
  sequencesFacture      SequenceFacture[]

  @@map("users")
}

/// Logs de connexion
model LoginLog {
  id        Int      @id @default(autoincrement())
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  email     String
  success   Boolean
  reason    String?  // "ok", "bad_password", "inactive", "not_found"
  ip        String?
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@index([email])
  @@map("login_logs")
}

/// Lien unique de feedback envoyé à un utilisateur ciblé
model FeedbackToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  response  FeedbackResponse?

  @@index([userId])
  @@map("feedback_tokens")
}

/// Réponse au formulaire de feedback
model FeedbackResponse {
  id          String        @id @default(cuid())
  tokenId     String        @unique @map("token_id")
  token       FeedbackToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  userId      String        @map("user_id")
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  lang        String        // "fr" | "en"
  rating      Int           // 1..10
  blockers    String[]      // codes des points bloquants cochés
  whatBlocked String?       @map("what_blocked")     // freins première visite (texte libre)
  missing     String?       // fonctionnalités manquantes (texte libre)
  modules     String[]      // modules utilisés (jardin, verger, elevage, ...)
  willReturn  String?       @map("will_return")     // yes / maybe / no
  comment     String?
  createdAt   DateTime      @default(now()) @map("created_at")

  @@index([userId])
  @@map("feedback_responses")
}

/// Sessions NextAuth
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime

  @@map("sessions")
}

// ============================================================
// NIVEAU 1 - RÉFÉRENTIELS INDÉPENDANTS
// ============================================================

/// Familles botaniques (rotation des cultures)
model Famille {
  id          String   @id @map("famille")
  intervalle  Int      @default(4) @map("intervalle") // Années entre 2 cultures de même famille
  couleur     String?  @map("couleur") // Code couleur UI (#RRGGBB)
  description String?  @map("description")

  // Relations
  especes            Espece[]
  associationDetails AssociationDetail[]

  @@map("familles")
}

/// Fournisseurs (semences, aliments, animaux)
model Fournisseur {
  id                 String   @id @map("fournisseur")
  contact            String?  @map("contact")
  adresse            String?  @map("adresse")
  ville              String?  @map("ville")
  codePostal         String?  @map("code_postal")
  pays               String?  @default("France") @map("pays")
  email              String?  @map("email")
  telephone          String?  @map("telephone")
  siteWeb            String?  @map("site_web")
  siret              String?  @map("siret")
  tvaIntra           String?  @map("tva_intra") // Numéro TVA intracommunautaire
  type               String?  @map("type") // "semences", "aliments", "animaux", "materiel", "mixte"
  conditionsPaiement Int?     @default(30) @map("conditions_paiement") // Délai paiement en jours
  notes              String?  @map("notes")
  actif              Boolean  @default(true) @map("actif")
  createdAt          DateTime @default(now()) @map("created_at")

  // Relations
  varietes  Variete[]
  aliments  Aliment[]

  @@map("fournisseurs")
}

/// Destinations des récoltes et ventes (vente, don, consommation)
model Destination {
  id          String  @id @map("destination")
  description String? @map("description")

  // Relations
  consommations  Consommation[]
  ventesProduits VenteProduit[]

  @@map("destinations")
}

/// Fertilisants (engrais, amendements)
model Fertilisant {
  id          String  @id @map("fertilisant")
  type        String? @map("type") // Organique, Minéral, etc.
  n           Float?  @map("n") // Azote (%)
  p           Float?  @map("p") // Phosphore (%)
  k           Float?  @map("k") // Potassium (%)
  ca          Float?  @map("ca") // Calcium (%)
  mg          Float?  @map("mg") // Magnésium (%)
  s           Float?  @map("s") // Soufre (%)
  densite     Float?  @map("densite") // kg/L
  prix        Float?  @map("prix") // €/kg
  stock       Float?  @map("stock") // Quantité en stock (kg ou L)
  dateStock   DateTime? @map("date_stock")
  description String? @map("description")

  // Relations
  fertilisations Fertilisation[]
  userStocks     UserStockFertilisant[]

  @@map("fertilisants")
}

// ============================================================
// NIVEAU 2 - DÉPENDANTS DES RÉFÉRENTIELS
// ============================================================

/// Espèces de plantes cultivables
model Espece {
  id              String   @id @map("espece")
  type            String   @default("legume") @map("type") // legume, aromatique, engrais_vert, arbre_fruitier, petit_fruit, ornement
  uniteRendement  String   @default("kg_m2") @map("unite_rendement") // kg_m2 | kg_arbre | biomasse_t_ha — voir docs/conventions.md
  familleId       String?  @map("famille")
  famille         Famille? @relation(fields: [familleId], references: [id], onDelete: SetNull)
  nomLatin        String?  @map("nom_latin")
  rendement       Float?   @map("rendement") // unité dépend de uniteRendement
  vivace          Boolean  @default(false) @map("vivace")
  besoinN         Float?   @map("besoin_n") // Besoin azote (1-5)
  besoinP         Float?   @map("besoin_p") // Besoin phosphore (1-5)
  besoinK         Float?   @map("besoin_k") // Besoin potassium (1-5)
  besoinEau       Float?   @map("besoin_eau") // Besoin eau (1-5)
  dateInventaire  DateTime? @map("date_inventaire")
  inventaire      Float?   @map("inventaire") // Stock (kg)
  aPlanifier      Boolean  @default(true) @map("a_planifier")
  couleur         String?  @map("couleur") // Code couleur UI (#RRGGBB)
  description     String?  @map("description")

  // Nouveaux champs (parité Potaleger)
  categorie       String?  @map("categorie")       // Catégorie visuelle (emoji)
  niveau          String?  @map("niveau")          // Facile, Moyen, Difficile
  densite         Float?   @map("densite")         // Plants/m²
  doseSemis       Float?   @map("dose_semis")      // g/m² — alimente le mode graine_directe
  tauxGermination Float?   @map("taux_germination") // % germination

  // PROMPT 06 — Calcul Semences fiabilisé : on ne calcule plus la même chose
  // pour une carotte (semis direct), une tomate (plant repiqué) et un ail
  // (caieu). Chaque espèce déclare son mode de propagation et ses paramètres.
  modeSemis        String?  @map("mode_semis")          // graine_directe | plant_repique | bulbe_caieu | bouture
  margeSecuritePct Int      @default(15) @map("marge_securite_pct")
  temperatureGerm String?  @map("temp_germination") // Ex: "15-25°C"
  joursLevee      Int?     @map("jours_levee")     // Nombre de jours
  irrigation      String?  @map("irrigation")      // Faible/Moyen/Élevé
  conservation    Boolean? @map("conservation")    // Se conserve bien ?
  effet           String?  @map("effet")           // Effet sur le sol/autres
  usages          String?  @map("usages")          // Usages culinaires
  objectifAnnuel  Float?   @map("obj_annuel")      // kg ou unités visées/an
  prixKg          Float?   @map("prix_kg")         // Prix de vente €/kg
  semaineTaille   Int?     @map("s_taille")        // Semaine de taille (1-52)

  // Relations
  varietes           Variete[]
  cultures           Culture[]
  recoltes           Recolte[]
  consommations      Consommation[]
  itps               ITP[]
  arbres             Arbre[]
  associationDetails AssociationDetail[]
  userStocks         UserStockEspece[]
  campagnesPlantation CampagnePlantation[]
  portesGreffe       PorteGreffeEspece[]
  bioagresseurs      BioagresseurEspece[]

  @@map("especes")
}

/// Porte-greffes (Pommier M9/MM106, Pêcher GF677, Cerisier Gisela5…)
model PorteGreffe {
  id              String   @id @default(cuid())
  nom             String   @unique @map("nom")
  vigueur         Int      @map("vigueur") // 1-5
  precocite       Int      @map("precocite") // 1-5
  sensibilites    String[] @map("sensibilites") // ['asphyxie','calcaire','secheresse']
  drageonnement   Boolean  @default(false) @map("drageonnement")
  notes           String?  @map("notes")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  especes         PorteGreffeEspece[]
  campagnes       CampagnePlantation[]
  arbres          Arbre[]              @relation("ArbrePorteGreffe")

  @@map("porte_greffes")
}

/// Jointure many-to-many porte_greffes ↔ especes (espèces fruitières portées)
model PorteGreffeEspece {
  porteGreffeId String      @map("porte_greffe_id")
  porteGreffe   PorteGreffe @relation(fields: [porteGreffeId], references: [id], onDelete: Cascade)
  especeId      String      @map("espece_id")
  espece        Espece      @relation(fields: [especeId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([porteGreffeId, especeId])
  @@index([especeId])
  @@map("porte_greffe_especes")
}

/// Bioagresseurs (maladies, ravageurs, adventices). PBI = Production Bio Intégrée.
model Bioagresseur {
  id               String   @id @default(cuid())
  nomCommun        String   @map("nom_commun")
  nomLatin         String   @map("nom_latin")
  type             String   @map("type") // 'Maladie' | 'Ravageur' | 'Adventice'
  organeCible      String   @map("organe_cible") // 'Feuille' | 'Fruit' | 'Bois' | 'Racine' | 'Tige'
  periodePression  String[] @map("periode_pression") // ['S10-S20']
  methodesPbi      String[] @map("methodes_pbi") // ['piège','filet','biocontrôle','traitement_AB']
  seuilNuisibilite String?  @map("seuil_nuisibilite")
  notes            String?  @map("notes")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  especes          BioagresseurEspece[]

  @@index([type])
  @@map("bioagresseurs")
}

/// Jointure many-to-many bioagresseurs ↔ especes (espèces cibles).
model BioagresseurEspece {
  bioagresseurId String       @map("bioagresseur_id")
  bioagresseur   Bioagresseur @relation(fields: [bioagresseurId], references: [id], onDelete: Cascade)
  especeId       String       @map("espece_id")
  espece         Espece       @relation(fields: [especeId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([bioagresseurId, especeId])
  @@index([especeId])
  @@map("bioagresseur_especes")
}

/// Essences bocagères (Aubépine, Charme, Cornouiller…) — Assistant Plantation
/// type "Haie / Bocage".
model EssenceBocagere {
  id          String   @id @default(cuid())
  nomCommun   String   @map("nom_commun")
  nomLatin    String   @map("nom_latin")
  hauteurM    Float    @map("hauteur_m")
  croissance  String   @map("croissance") // 'Lente' | 'Moyenne' | 'Rapide'
  roles       String[] @map("roles") // ['brise-vent','refuge auxiliaires','mellifère','bois énergie']
  persistant  Boolean  @default(false) @map("persistant")
  epineux     Boolean  @default(false) @map("epineux")
  notes       String?  @map("notes")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([nomLatin])
  @@map("essences_bocageres")
}

/// Variétés (cultivars d'espèces)
model Variete {
  id             String       @id @map("variete")
  nomNormalise   String       @map("nom_normalise") // Clé déduplication, peuplée via normalizeVarieteName
  isPlaceholder  Boolean      @default(false) @map("is_placeholder") // "Non spécifiée" — affiche bandeau "À renseigner"
  especeId       String       @map("espece")
  espece         Espece       @relation(fields: [especeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  fournisseurId  String?      @map("fournisseur")
  fournisseur    Fournisseur? @relation(fields: [fournisseurId], references: [id], onDelete: SetNull)
  semaineRecolte Int?         @map("s_recolte") // Semaine récolte théorique (1-52)
  dureeRecolte   Int?         @map("d_recolte") // Durée période récolte (semaines)
  nbGrainesG     Float?       @map("nb_graines_g") // Nombre graines/gramme
  prixGraine     Float?       @map("prix_graine") // €/kg ou €/1000 graines
  stockGraines   Float?       @map("stock_graines") // Quantité graines en stock (g)
  stockPlants    Int?         @map("stock_plants")  // Quantité plants en stock
  dateStock      DateTime?    @map("date_stock")
  bio            Boolean      @default(false) @map("bio")
  description    String?      @map("description")

  // PROMPT 05 — Audit Verger : différenciation unifère/bifère pour les figuiers.
  // Valeurs : 'unifere' (1 récolte par an) | 'bifere' (2 récoltes : figues-fleurs
  // en juin-juillet, figues d'automne en août-octobre).
  unifereBifere  String?      @map("unifere_bifere")

  // Relations
  cultures         Culture[]
  userStocks       UserStockVariete[]

  @@unique([especeId, nomNormalise], name: "espece_nom_normalise")
  @@index([isPlaceholder])
  @@map("varietes")
}

/// ITP - Itinéraires Techniques des Plantes
model ITP {
  id                String  @id @map("it_plante")
  especeId          String? @map("espece")
  espece            Espece? @relation(fields: [especeId], references: [id], onDelete: SetNull)
  semaineSemis      Int?    @map("s_semis") // Semaine semis (1-52)
  semainePlantation Int?    @map("s_plantation") // Semaine plantation (1-52)
  semaineRecolte    Int?    @map("s_recolte") // Semaine début récolte (1-52)
  dureeRecolte      Int?    @map("d_recolte") // Durée récolte (semaines, 1-52)
  dureePepiniere    Int?    @map("d_pepiniere") // Durée pépinière (jours)
  dureeCulture      Int?    @map("d_culture") // Durée culture (jours)
  nbRangs           Int?    @map("nb_rangs") // Nombre de rangs par planche
  espacement        Float?  @map("espacement") // Espacement entre plants (cm)
  notes             String? @map("notes")

  // Nouveaux champs (parité Potaleger)
  typePlanche     String?  @map("type_planche")     // Plein champ | Sous abri (Serre/Tunnel)
  decalageMax     Int?     @map("decal_max")        // Semaines de flexibilité (0-52)
  espacementRangs Int?     @map("esp_rangs")        // cm entre rangs
  nbGrainesPlant  Float?   @map("nb_graines_plant") // Graines par plant
  doseSemis       Float?   @map("dose_semis")       // g/m² ou g/ml

  // PROMPT 05 — Audit agronomique : décorrélation du mode de démarrage et du
  // type de planche, traçabilité des révisions.
  // - typePlanche  → où la culture grandit (Plein champ / Sous abri).
  // - modeDemarrage → comment elle est semée (Plein champ / Sous abri / Pépinière).
  modeDemarrage       String?   @map("mode_demarrage")
  commentaireAgronome String?   @map("commentaire_agronome")
  sourceReference     String?   @map("source_reference")
  derniereRevision    DateTime? @map("derniere_revision")

  // Relations
  cultures         Culture[]
  rotationsDetails RotationDetail[]

  @@map("itps")
}

// ============================================================
// NIVEAU 3 - INFRASTRUCTURE SPATIALE ET TEMPORELLE
// ============================================================

/// Plans de rotation des cultures
model Rotation {
  id       String  @id @map("rotation")
  active   Boolean @default(true) @map("active")
  nbAnnees Int?    @map("nb_annees") // Calculé depuis les détails
  notes    String? @map("notes")

  // Relations
  details  RotationDetail[]
  planches Planche[]

  @@map("rotations")
}

/// Détails des rotations (années)
model RotationDetail {
  id         Int      @id @default(autoincrement())
  rotationId String   @map("rotation")
  rotation   Rotation @relation(fields: [rotationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  itpId      String?  @map("it_plante")
  itp        ITP?     @relation(fields: [itpId], references: [id], onDelete: SetNull)
  annee      Int      @map("annee") // Position dans le cycle (1, 2, 3...)

  @@map("rotations_details")
}

/// Planches de culture (parcelles)
model Planche {
  id                  String    @id @default(cuid())
  nom                 String    @map("nom")
  userId              String    @map("user_id")
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  rotationId          String?   @map("rotation")
  rotation            Rotation? @relation(fields: [rotationId], references: [id], onDelete: SetNull)
  largeur             Float?    @map("largeur") // mètres
  longueur            Float?    @map("longueur") // mètres
  surface             Float?    @map("surface") // m² (calculé: largeur × longueur)
  // Position sur le plan du jardin
  posX                Float?    @map("pos_x") // Position X en mètres
  posY                Float?    @map("pos_y") // Position Y en mètres
  rotation2D          Float?    @default(0) @map("rotation_2d") // Rotation en degrés
  planchesInfluencees String?   @map("planches_influencees") // CSV des planches proches (associations)
  ilot                String?   @map("ilot") // Groupement de planches
  parcelleGeoId       String?   @map("parcelle_geo_id")
  parcelleGeo         ParcelleGeo? @relation(fields: [parcelleGeoId], references: [id], onDelete: SetNull)
  notes               String?   @map("notes")

  // Nouveaux champs (parité Potaleger)
  type                String?   @map("type")       // Serre, Plein champ, Tunnel, Châssis
  irrigation          String?   @map("irrigation") // Goutte-à-goutte, Aspersion, Manuel, Aucun
  annee               Int?      @map("annee")      // Année de référence pour rotation

  // Qualité du sol (influence irrigation/fertilisation)
  typeSol             String?   @map("type_sol")         // Argileux, Limoneux, Sableux, Mixte
  retentionEau        String?   @map("retention_eau")    // Faible, Moyenne, Élevée
  argile              Float?    @map("argile_pct")       // % argile (0-100)
  limon               Float?    @map("limon_pct")        // % limon
  sable               Float?    @map("sable_pct")        // % sable
  phSol               Float?    @map("ph_sol")           // pH du sol
  carboneOrg          Float?    @map("carbone_org")      // % carbone organique
  derniereAnalyseSol  DateTime? @map("derniere_analyse") // Date dernière maj données sol

  // PROMPT 12 — Statut Bio (Conventionnel | C1 | C2 | C3 | AB)
  statutBio            String    @default("Conventionnel") @map("statut_bio")
  dateDebutConversion  DateTime? @map("date_debut_conversion")
  certificateur        String?   @map("certificateur")
  nCertificat          String?   @map("n_certificat")

  // Relations
  cultures       Culture[]
  fertilisations Fertilisation[]
  analyses       AnalyseSol[]

  @@unique([nom, userId])
  @@index([userId])
  @@index([userId, ilot])
  @@map("planches")
}

/// Parcelle géoréférencée (cartographie)
model ParcelleGeo {
  id              String    @id @default(cuid())
  nom             String    @map("nom")
  userId          String    @map("user_id")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // GeoJSON geometry stocké en texte (pas de PostGIS natif dans Prisma)
  geometry        String    @map("geometry") // GeoJSON Polygon/MultiPolygon
  centroidLat     Float?    @map("centroid_lat")
  centroidLng     Float?    @map("centroid_lng")
  surface         Float?    @map("surface_ha") // Surface en hectares

  // Données cadastrales
  commune         String?   @map("commune")
  section         String?   @map("section_cadastrale")
  numero          String?   @map("numero_parcelle")
  prefixe         String?   @map("prefixe")
  contenance      Float?    @map("contenance") // Surface cadastrale m²

  // Couches d'activité
  couches         CoucheActivite[] @default([])

  // Données agronomiques
  typeSol         String?   @map("type_sol")
  usage           String?   @map("usage") // culture, prairie, verger, friche...
  couleur         String?   @map("couleur") // Couleur d'affichage #RRGGBB
  notes           String?   @map("notes")

  // Planches, objets et arbres rattachés à cette parcelle
  planches        Planche[]
  objetsJardin    ObjetJardin[]
  arbres          Arbre[]
  lotsAnimaux     LotAnimaux[]
  campagnesPlantation CampagnePlantation[]

  // PROMPT 12 — Statut Bio (Conventionnel | C1 | C2 | C3 | AB)
  statutBio            String    @default("Conventionnel") @map("statut_bio")
  dateDebutConversion  DateTime? @map("date_debut_conversion")
  certificateur        String?   @map("certificateur")
  nCertificat          String?   @map("n_certificat")

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@map("parcelles_geo")
}

/// Analyses de sol
model AnalyseSol {
  id            String    @id @default(cuid())
  nom           String    @map("nom")
  userId        String    @map("user_id")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plancheId     String?   @map("planche")
  planche       Planche?  @relation(fields: [plancheId], references: [id], onDelete: SetNull)
  dateAnalyse   DateTime? @map("date_analyse")
  laboratoire   String?   @map("laboratoire")
  // Texture
  argile        Float?    @map("argile") // %
  limon         Float?    @map("limon") // %
  sable         Float?    @map("sable") // %
  // Chimie
  ph            Float?    @map("ph")
  matiereOrg    Float?    @map("mo") // Matière organique %
  cec           Float?    @map("cec") // Capacité d'échange cationique
  // Éléments majeurs
  n             Float?    @map("n") // Azote total
  p             Float?    @map("p") // Phosphore assimilable (Olsen)
  k             Float?    @map("k") // Potassium échangeable
  ca            Float?    @map("ca") // Calcium échangeable
  mg            Float?    @map("mg") // Magnésium échangeable
  na            Float?    @map("na") // Sodium échangeable
  // Oligo-éléments
  fe            Float?    @map("fe") // Fer
  mn            Float?    @map("mn") // Manganèse
  cu            Float?    @map("cu") // Cuivre
  zn            Float?    @map("zn") // Zinc
  b             Float?    @map("b") // Bore
  notes         String?   @map("notes")

  @@unique([nom, userId])
  @@index([userId])
  @@index([plancheId])
  @@map("analyses_de_sol")
}

// ============================================================
// NIVEAU 4 - OPÉRATIONNEL (TRANSACTIONS)
// ============================================================

/// Cultures (instances de semis/plantation)
model Culture {
  id              Int       @id @default(autoincrement())
  userId          String    @map("user_id")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  especeId        String    @map("espece")
  espece          Espece    @relation(fields: [especeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  varieteId       String?   @map("variete")
  variete         Variete?  @relation(fields: [varieteId], references: [id], onDelete: SetNull)
  itpId           String?   @map("it_plante")
  itp             ITP?      @relation(fields: [itpId], references: [id], onDelete: SetNull)
  plancheId       String?   @map("planche")
  planche         Planche?  @relation(fields: [plancheId], references: [id], onDelete: SetNull)

  // Planification
  annee           Int?      @map("annee") // Année de planification
  dateSemis       DateTime? @map("date_semis")
  datePlantation  DateTime? @map("date_plantation")
  dateRecolte     DateTime? @map("date_recolte")

  // État d'avancement
  semisFait       Boolean   @default(false) @map("semis_fait")
  plantationFaite Boolean   @default(false) @map("plantation_faite")
  recolteFaite    Boolean   @default(false) @map("recolte_faite")
  terminee        String?   @map("terminee") // NULL, 'x' (terminée), 'v' (vivace continue), 'NS' (non significative)

  // Quantités
  quantite        Float?    @map("quantite") // Surface ou nb plants
  nbRangs         Int?      @map("nb_rangs")
  longueur        Float?    @map("longueur") // mètres
  espacement      Int?      @map("espacement") // cm entre plants

  // Nouveaux champs (parité Potaleger)
  finRecolte          DateTime? @map("fin_recolte") // Date fin récolte
  aFaire              String?   @map("a_faire")     // Tâches à faire
  dPlanif             String?   @map("d_planif")    // Date de planification
  aIrriguer           Boolean?  @map("a_irriguer")  // Besoin d'irrigation
  derniereIrrigation  DateTime? @map("derniere_irrigation") // Dernière date d'arrosage

  // PROMPT 12 — Traçabilité rotation : true si l'utilisateur a validé la
  // création malgré le warning de violation de plan de rotation.
  rotationViolee  Boolean   @default(false) @map("rotation_violee")

  notes           String?   @map("notes")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  recoltes Recolte[]
  irrigationsPlanifiees IrrigationPlanifiee[]

  @@index([userId])
  @@index([userId, annee])
  @@index([especeId])
  @@index([plancheId])
  @@index([dateSemis])
  @@index([datePlantation])
  @@index([dateRecolte])
  @@index([aIrriguer])
  @@map("cultures")
}

/// Récoltes
model Recolte {
  id             Int       @id @default(autoincrement())
  userId         String    @map("user_id")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  especeId       String    @map("espece")
  espece         Espece    @relation(fields: [especeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  cultureId      Int       @map("culture")
  culture        Culture   @relation(fields: [cultureId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  date           DateTime  @default(now()) @map("date")
  quantite       Float     @map("quantite") // kg
  // Statut et vente
  statut         String    @default("en_stock") @map("statut") // "en_stock", "vendu", "consomme", "perte"
  dateVente      DateTime? @map("date_vente")
  prixKg         Float?    @map("prix_kg")
  prixTotal      Float?    @map("prix_total")
  clientId       Int?      @map("client_id")
  clientNom      String?   @map("client_nom")
  factureId      Int?      @map("facture_id")
  // Péremption (pour sortie auto du stock)
  datePeremption DateTime? @map("date_peremption") // Date limite avant que le produit soit périmé
  // PROMPT 12 — Snapshot du statut Bio AU MOMENT de la récolte (n'évolue plus).
  statutBioSnapshot String? @map("statut_bio_snapshot") // Conventionnel | C1 | C2 | C3 | AB
  notes          String?   @map("notes")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([especeId])
  @@index([cultureId])
  @@index([cultureId, date])
  @@index([date])
  @@index([statut])
  @@index([statutBioSnapshot])
  @@map("recoltes")
}

/// Irrigations planifiées
model IrrigationPlanifiee {
  id             Int      @id @default(autoincrement())
  userId         String   @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cultureId      Int      @map("culture_id")
  culture        Culture  @relation(fields: [cultureId], references: [id], onDelete: Cascade)
  datePrevue     DateTime @map("date_prevue")
  fait           Boolean  @default(false) @map("fait")
  dateEffective  DateTime? @map("date_effective") // Date réelle si différente
  notes          String?  @map("notes") @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([cultureId])
  @@index([datePrevue])
  @@map("irrigations_planifiees")
}

/// Consommations (sorties de stock)
model Consommation {
  id            Int          @id @default(autoincrement())
  userId        String       @map("user_id")
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  especeId      String       @map("espece")
  espece        Espece       @relation(fields: [especeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  destinationId String?      @map("destination")
  destination   Destination? @relation(fields: [destinationId], references: [id], onDelete: SetNull)
  date          DateTime     @default(now()) @map("date")
  quantite      Float        @map("quantite") // kg
  prix          Float?       @map("prix") // € total
  notes         String?      @map("notes")
  createdAt     DateTime     @default(now()) @map("created_at")

  @@index([userId])
  @@index([especeId])
  @@index([date])
  @@map("consommations")
}

/// Fertilisations (apports)
model Fertilisation {
  id            Int         @id @default(autoincrement())
  userId        String      @map("user_id")
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  plancheId     String      @map("planche")
  planche       Planche     @relation(fields: [plancheId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  fertilisantId String      @map("fertilisant")
  fertilisant   Fertilisant @relation(fields: [fertilisantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  date          DateTime    @default(now()) @map("date")
  quantite      Float       @map("quantite") // kg ou L
  notes         String?     @map("notes")
  createdAt     DateTime    @default(now()) @map("created_at")

  @@index([userId])
  @@index([userId, date])
  @@index([plancheId, date])
  @@map("fertilisations")
}

/// Notes générales
model Note {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  titre     String?  @map("titre")
  contenu   String?  @map("contenu") // Markdown
  categorie String?  @map("categorie") // Catégorie libre
  date      DateTime @default(now()) @map("date")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("notes")
}

/// Paramètres de l'application
model Parametre {
  id     String  @id @map("parametre")
  valeur String? @map("valeur")

  @@map("params")
}

/// Objets du jardin (allées, passages, bordures, serres, etc.)
model ObjetJardin {
  id          Int      @id @default(autoincrement())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nom         String?  @map("nom")
  type        String   @map("type") // "allee", "passage", "bordure", "serre", "compost", "autre"
  largeur     Float    @map("largeur") // mètres
  longueur    Float    @map("longueur") // mètres
  posX        Float    @map("pos_x") // Position X en mètres
  posY        Float    @map("pos_y") // Position Y en mètres
  rotation2D  Float    @default(0) @map("rotation_2d") // Rotation en degrés
  parcelleGeoId  String?      @map("parcelle_geo_id")
  parcelleGeo    ParcelleGeo? @relation(fields: [parcelleGeoId], references: [id], onDelete: SetNull)
  couleur     String?  @map("couleur") // Code couleur (#RRGGBB)
  notes       String?  @map("notes")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("objets_jardin")
}

/// Arbres et arbustes (fruitiers, petits fruits, forestiers, ornementaux)
model Arbre {
  id              Int       @id @default(autoincrement())
  userId          String    @map("user_id")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  nom             String    @map("nom") // Nom d'affichage (ex: "Pommier Golden")
  type            String    @map("type") // "fruitier", "petit_fruit", "forestier", "ornement", "haie"
  especeId        String?   @map("espece_id") // Lien optionnel vers le catalogue Espece
  especeRef       Espece?   @relation(fields: [especeId], references: [id], onDelete: SetNull)
  espece          String?   @map("espece") // Espèce texte libre (ex: "Pommier", "Framboisier")
  variete         String?   @map("variete") // Variété (ex: "Golden", "Malling Promise")
  portGreffe      String?   @map("port_greffe") // Porte-greffe (texte libre, rétro-compat)
  porteGreffeId   String?   @map("porte_greffe_id") // FK référentiel PorteGreffe (PROMPT 10)
  porteGreffeRef  PorteGreffe? @relation("ArbrePorteGreffe", fields: [porteGreffeId], references: [id], onDelete: SetNull)
  circonferenceCm Float?    @map("circonference_cm") // Mesure standard tronc — utile PCAE/HVE
  gpsLat          Float?    @map("gps_lat") // Latitude WGS84
  gpsLng          Float?    @map("gps_lng") // Longitude WGS84
  fournisseur     String?   @map("fournisseur") // Lieu d'achat / pépinière
  dateAchat       DateTime? @map("date_achat")
  prixAchat       Float?    @map("prix_achat") // Prix d'achat en €
  datePlantation  DateTime? @map("date_plantation")
  age             Int?      @map("age") // Âge à la plantation (années)
  // Position sur le plan
  posX            Float     @map("pos_x")
  posY            Float     @map("pos_y")
  envergure       Float     @default(2) @map("envergure") // Diamètre en mètres (pour affichage)
  // Infos complémentaires
  hauteur         Float?    @map("hauteur") // Hauteur actuelle en mètres
  etat            String?   @map("etat") // "excellent", "bon", "moyen", "mauvais", "mort"
  pollinisateur   String?   @map("pollinisateur") // Variété pollinisatrice associée
  couleur         String?   @map("couleur") // Couleur d'affichage sur le plan
  parcelleGeoId   String?   @map("parcelle_geo_id")
  parcelleGeo     ParcelleGeo? @relation(fields: [parcelleGeoId], references: [id], onDelete: SetNull)
  notes           String?   @map("notes")
  // Gestion production
  productif       Boolean   @default(true) @map("productif") // Est-ce que l'arbre produit ?
  anneeProduction Int?      @map("annee_production") // Première année de production
  rendementMoyen  Float?    @map("rendement_moyen") // kg/an estimé
  // Forme & structure
  formeTaille       String?   @map("forme_taille") // "gobelet", "fuseau", "palmette_u", "palmette_verrier", "cordon", "espalier", "plein_vent", "quenouille", "axe"
  vigueur           String?   @map("vigueur") // "faible", "moyenne", "forte"
  distancePlantation Float?  @map("distance_plantation") // mètres entre arbres
  distanceRang      Float?   @map("distance_rang") // mètres entre rangs
  orientationRang   String?  @map("orientation_rang") // "N-S", "E-O", "NE-SO", "NO-SE"
  surfaceCanopee    Float?   @map("surface_canopee") // m² calculé
  // Greffe
  dateGreffe        DateTime? @map("date_greffe")
  typeGreffe        String?   @map("type_greffe") // "fente", "couronne", "ecussonnage", "anglaise"
  // Suppression / fin de vie
  dateSuppression   DateTime? @map("date_suppression")
  causeSuppression  String?   @map("cause_suppression") // "mort", "arrachage", "maladie", "improductif"
  // Pollinisation & floraison
  heuresFroidRequis Int?      @map("heures_froid_requis") // Heures < 7°C nécessaires
  floraison         String?   @map("floraison") // "tres_precoce", "precoce", "moyenne", "tardive", "tres_tardive"
  groupePollinisation String? @map("groupe_pollinisation") // "A", "B", "C", "D"
  autofertile       Boolean   @default(false) @map("autofertile")
  periodeRecolte    String?   @map("periode_recolte") // "juin", "juillet", etc.
  conservation      String?   @map("conservation") // "courte", "moyenne", "longue"
  // Zone verger
  zoneId            Int?      @map("zone_id")
  zone              ZoneVerger? @relation(fields: [zoneId], references: [id], onDelete: SetNull)

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations module arbres
  recoltesArbres       RecolteArbre[]
  productionsBois      ProductionBois[]
  operationsArbres     OperationArbre[]
  pollinisateursCompat PollinisationArbre[] @relation("ArbrePollinise")
  pollinisateurDe      PollinisationArbre[] @relation("ArbrePollinisateur")
  observationsSante    ObservationSante[]

  @@index([userId])
  @@index([type])
  @@index([especeId])
  @@index([zoneId])
  @@index([porteGreffeId])
  @@map("arbres")
}

// ============================================================
// MODULE ARBRES - RÉCOLTES, BOIS, OPÉRATIONS
// ============================================================

/// Récoltes d'arbres (fruits, noix, etc.)
model RecolteArbre {
  id             Int       @id @default(autoincrement())
  userId         String    @map("user_id")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  arbreId        Int       @map("arbre_id")
  arbre          Arbre     @relation(fields: [arbreId], references: [id], onDelete: Cascade)
  date           DateTime  @default(now()) @map("date")
  quantite       Float     @map("quantite") // kg
  qualite        String?   @map("qualite") // "excellent", "bon", "moyen", "mauvais"
  prixKg         Float?    @map("prix_kg") // Prix de vente €/kg
  // Statut et vente
  statut         String    @default("en_stock") @map("statut") // "en_stock", "vendu", "consomme", "perte"
  dateVente      DateTime? @map("date_vente")
  prixTotal      Float?    @map("prix_total")
  clientId       Int?      @map("client_id")
  clientNom      String?   @map("client_nom")
  factureId      Int?      @map("facture_id")
  facture        Facture?  @relation("RecolteArbreFacture", fields: [factureId], references: [id])
  datePeremption DateTime? @map("date_peremption")
  // PROMPT 12 — Snapshot du statut Bio AU MOMENT de la récolte (n'évolue plus).
  statutBioSnapshot String? @map("statut_bio_snapshot") // Conventionnel | C1 | C2 | C3 | AB
  notes          String?   @map("notes")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([arbreId])
  @@index([date])
  @@index([statut])
  @@index([factureId])
  @@index([statutBioSnapshot])
  @@map("recoltes_arbres")
}

/// Production de bois (élagage, abattage, branchage)
model ProductionBois {
  id          Int       @id @default(autoincrement())
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  arbreId     Int?      @map("arbre_id") // Null si arbre abattu/supprimé
  arbre       Arbre?    @relation(fields: [arbreId], references: [id], onDelete: SetNull)
  date        DateTime  @default(now()) @map("date")
  type        String    @map("type") // "elagage", "abattage", "branchage"
  volumeM3    Float?    @map("volume_m3") // Stères ou m³
  poidsKg     Float?    @map("poids_kg")
  // Statut et destination
  statut      String    @default("en_stock") @map("statut") // "en_stock", "vendu", "utilise"
  destination String?   @map("destination") // "chauffage", "BRF", "vente", "construction"
  // Vente
  dateVente   DateTime? @map("date_vente")
  prixVente   Float?    @map("prix_vente") // € si vendu
  clientId    Int?      @map("client_id")
  clientNom   String?   @map("client_nom")
  factureId   Int?      @map("facture_id")
  facture     Facture?  @relation("ProductionBoisFacture", fields: [factureId], references: [id])
  notes       String?   @map("notes")
  createdAt   DateTime  @default(now()) @map("created_at")

  // Replantation : campagnes générées suite à cette coupe
  campagnesReplantation CampagnePlantation[]

  @@index([userId])
  @@index([arbreId])
  @@index([date])
  @@index([statut])
  @@index([factureId])
  @@map("production_bois")
}

/// Opérations sur arbres (taille, greffe, traitement, fertilisation)
model OperationArbre {
  id          Int       @id @default(autoincrement())
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  arbreId     Int       @map("arbre_id")
  arbre       Arbre     @relation(fields: [arbreId], references: [id], onDelete: Cascade)
  date        DateTime  @default(now()) @map("date")
  type        String    @map("type") // "taille", "greffe", "traitement", "fertilisation", "autre"
  description String?   @map("description")
  produit     String?   @map("produit") // Produit utilisé
  quantite    Float?    @map("quantite") // Quantité
  unite       String?   @map("unite") // L, kg, etc.
  cout        Float?    @map("cout") // Coût en €
  datePrevue  DateTime? @map("date_prevue") // Date planifiée (si tâche future)
  fait        Boolean   @default(true) @map("fait")
  dureeMinutes    Int?      @map("duree_minutes")
  nbPersonnes     Int?      @default(1) @map("nb_personnes")
  recurrence      String?   @map("recurrence") // "annuelle", "semestrielle", "mensuelle"
  saisonRecommandee String? @map("saison_recommandee") // "hiver", "printemps", "ete", "automne"
  notes       String?   @map("notes")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([arbreId])
  @@index([type])
  @@index([fait])
  @@index([datePrevue])
  @@map("operations_arbres")
}

// ============================================================
// MODULE VERGER - ZONES, POLLINISATION, SANTÉ
// ============================================================

/// Zones de verger (regroupement spatial d'arbres)
model ZoneVerger {
  id              Int       @id @default(autoincrement())
  userId          String    @map("user_id")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  nom             String    @map("nom")
  type            String    @default("verger") @map("type") // "verger", "haie", "bosquet", "agroforesterie"
  surface         Float?    @map("surface") // m²
  exposition      String?   @map("exposition") // "nord", "sud", "est", "ouest", "plat"
  altitude        Int?      @map("altitude") // mètres
  protectionVent  String?   @map("protection_vent") // "aucune", "haie", "mur", "filet"
  typeSol         String?   @map("type_sol")
  irrigation      String?   @map("irrigation") // "goutte_a_goutte", "aspersion", "micro_aspersion", "aucune"
  notes           String?   @map("notes")
  createdAt       DateTime  @default(now()) @map("created_at")

  // PROMPT 12 — Statut Bio
  statutBio            String    @default("Conventionnel") @map("statut_bio")
  dateDebutConversion  DateTime? @map("date_debut_conversion")
  certificateur        String?   @map("certificateur")
  nCertificat          String?   @map("n_certificat")

  arbres          Arbre[]
  campagnesPlantation CampagnePlantation[]

  @@index([userId])
  @@map("zones_verger")
}

/// Compatibilités de pollinisation entre arbres
model PollinisationArbre {
  id                   Int    @id @default(autoincrement())
  arbrePolliniseId     Int    @map("arbre_pollinise_id")
  arbrePollinise       Arbre  @relation("ArbrePollinise", fields: [arbrePolliniseId], references: [id], onDelete: Cascade)
  arbrePollinisateurId Int    @map("arbre_pollinisateur_id")
  arbrePollinisateur   Arbre  @relation("ArbrePollinisateur", fields: [arbrePollinisateurId], references: [id], onDelete: Cascade)
  compatibilite        String @default("bonne") @map("compatibilite") // "excellente", "bonne", "partielle", "incompatible"
  notes                String? @map("notes")

  @@unique([arbrePolliniseId, arbrePollinisateurId])
  @@index([arbrePolliniseId])
  @@index([arbrePollinisateurId])
  @@map("pollinisation_arbres")
}

/// Observations de santé des arbres (fiche santé longitudinale)
model ObservationSante {
  id             Int       @id @default(autoincrement())
  userId         String    @map("user_id")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  arbreId        Int       @map("arbre_id")
  arbre          Arbre     @relation(fields: [arbreId], references: [id], onDelete: Cascade)
  date           DateTime  @default(now()) @map("date")
  type           String    @map("type") // "maladie", "ravageur", "carence", "degat_climatique", "observation_generale", "vigueur"
  symptome       String?   @map("symptome")
  diagnostic     String?   @map("diagnostic") // Nom de la maladie/ravageur
  gravite        String    @default("faible") @map("gravite") // "faible", "moyenne", "grave", "critique"
  organe         String?   @map("organe") // "feuilles", "fruits", "branches", "tronc", "racines", "fleurs"
  traitement     String?   @map("traitement") // Traitement appliqué (description de l'action)
  methodeTraitement String? @map("methode_traitement") // "chimique", "biologique", "mecanique" — null = non renseigné
  produit        String?   @map("produit") // Produit utilisé
  doseAppliquee  Float?    @map("dose_appliquee")
  uniteDose      String?   @map("unite_dose")
  dar            Int?      @map("dar") // Délai Avant Récolte (jours)
  numAMM         String?   @map("num_amm") // N° AMM du produit phyto
  resolu         Boolean   @default(false) @map("resolu")
  dateResolution DateTime? @map("date_resolution")
  notes          String?   @map("notes")
  createdAt      DateTime  @default(now()) @map("created_at")
  // PROMPT 11 LOT D — Enrichissement PBI
  stadeBBCH         String? @map("stade_bbch")          // ex: "BBCH 65 - pleine floraison"
  pctOrganesTouches Int?    @map("pct_organes_touches") // 0-100
  photoUrl          String? @map("photo_url")

  // PROMPT 11 LOT D — Interventions phyto déclenchées par cette observation.
  interventionsLiees Intervention[] @relation("InterventionObservation")

  @@index([userId])
  @@index([arbreId])
  @@index([date])
  @@index([type])
  @@index([resolu])
  @@map("observations_sante")
}

// ============================================================
// MODULE REPLANTATION - CAMPAGNES DE PLANTATION
// ============================================================

/// Campagne de plantation (replantation forestière, verger, haie, agroforesterie)
/// Permet de gérer en lot des plantations de plusieurs dizaines à milliers de plants
/// sans créer un Arbre individuel par plant.
model CampagnePlantation {
  id              Int       @id @default(autoincrement())
  userId          String    @map("user_id")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  nom             String    @map("nom") // ex: "Replantation parcelle Nord 2026"
  // Type de formation forestière / vergère
  typeFormation   String    @map("type_formation") // "verger", "haie", "agroforesterie", "forestier_futaie", "forestier_taillis", "bosquet", "miscanthus"
  // Nature de l'opération
  nature          String    @default("boisement") @map("nature") // "boisement" (terrain nu), "replantation_apres_coupe" (anc. reboisement), "regarnissage", "replantation_apres_mortalite" (anc. remplacement), "renouvellement"
  // Cause de la replantation (si applicable) - critique en sylviculture
  cause           String?   @map("cause") // "coupe_programmee", "scolytes", "tempete", "secheresse", "incendie", "echec_plantation", "maladie", "renouvellement_normal", "autre"
  // Peuplement précédent (avant la replantation)
  peuplementPrecedent String? @map("peuplement_precedent") // Description libre du peuplement
  essencePrecedente   String? @map("essence_precedente") // Essence dominante précédente
  // Champs Assistant Plantation (PROMPT 09) — pertinents surtout pour verger / agroforesterie fruitière.
  porteGreffeId       String?       @map("porte_greffe_id")
  porteGreffe         PorteGreffe?  @relation(fields: [porteGreffeId], references: [id], onDelete: SetNull)
  typePlant           String?       @map("type_plant") // Scion | Fléché | Baliveau | Haute-tige | Demi-tige | Basse-tige
  conduite            String?       @map("conduite") // Gobelet | Axe central | Palmette | Espalier | Libre
  labelProvenance     String?       @map("label_provenance") // MFR contrôlé | Végétal Local | Plante Bleue | Pépinière certifiée Bio | Aucun
  ageAvantCoupe       Int?    @map("age_avant_coupe") // Age du peuplement au moment de la coupe
  surfacePrecedenteHa Float?  @map("surface_precedente_ha") // Surface du peuplement initial (avant replantation partielle)
  // Lien optionnel à la coupe d'origine
  productionBoisId Int?     @map("production_bois_id")
  productionBois   ProductionBois? @relation(fields: [productionBoisId], references: [id], onDelete: SetNull)
  // Localisation
  parcelleGeoId   String?   @map("parcelle_geo_id")
  parcelleGeo     ParcelleGeo? @relation(fields: [parcelleGeoId], references: [id], onDelete: SetNull)
  zoneVergerId    Int?      @map("zone_verger_id")
  zoneVerger      ZoneVerger? @relation(fields: [zoneVergerId], references: [id], onDelete: SetNull)
  surfaceHa       Float?    @map("surface_ha") // hectares
  // Essence principale (mélange possible décrit dans notes)
  especeId        String?   @map("espece_id")
  espece          Espece?   @relation(fields: [especeId], references: [id], onDelete: SetNull)
  essenceLibre    String?   @map("essence_libre") // texte libre si pas dans Espece
  varieteOuProvenance String? @map("variete_ou_provenance") // "Chêne sessile RPV-Nord", "Douglas Washington"
  // Densité et volumes
  nombrePlants    Int?      @map("nombre_plants") // total commandé / planté
  densitePlantsParHa Float? @map("densite_plants_par_ha")
  ecartementRang  Float?    @map("ecartement_rang") // mètres entre rangs
  ecartementPlant Float?    @map("ecartement_plant") // mètres entre plants
  // Fournisseur & coût
  pepiniere       String?   @map("pepiniere")
  prixUnitaire    Float?    @map("prix_unitaire") // € par plant
  budgetPrevu     Float?    @map("budget_prevu") // € total estimé
  coutReel        Float?    @map("cout_reel") // € total réel
  aidesObtenues   String?   @map("aides_obtenues") // texte libre : "DEFI Forêt 60%, Région 20%"
  montantAides    Float?    @map("montant_aides") // € total des aides perçues
  // Cycle de vie de la campagne
  statut          String    @default("planifiee") @map("statut") // "planifiee", "prep_sol", "plantation", "suivi", "terminee", "echec"
  datePlantationPrevue DateTime? @map("date_plantation_prevue")
  datePlantationReelle DateTime? @map("date_plantation_reelle")
  // Suivi de reprise (calculé / dernière obs)
  tauxReprise     Float?    @map("taux_reprise") // % vivants (0-100)
  dateDernObservation DateTime? @map("date_derniere_observation")
  // Protection
  protectionType  String?   @map("protection_type") // "manchon", "filet", "cloture", "aucune"
  // Notes & objectifs
  objectifs       String?   @map("objectifs") // "bois oeuvre", "BRF", "biomasse", "biodiversité", "fruits"
  notes           String?   @map("notes")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  etapes          EtapeCampagne[]
  observations    ObservationCampagne[]

  @@index([userId])
  @@index([typeFormation])
  @@index([statut])
  @@index([parcelleGeoId])
  @@index([zoneVergerId])
  @@index([productionBoisId])
  @@map("campagnes_plantation")
}

/// Etapes du cycle d'une campagne de plantation (préparation, plantation, suivi)
model EtapeCampagne {
  id          Int       @id @default(autoincrement())
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  campagneId  Int       @map("campagne_id")
  campagne    CampagnePlantation @relation(fields: [campagneId], references: [id], onDelete: Cascade)
  type        String    @map("type") // "preparation_sol", "plantation", "regarnissage", "degagement", "elagage_formation", "protection_gibier", "fertilisation", "arrosage", "evaluation"
  ordre       Int       @default(0) @map("ordre") // ordre dans le calendrier
  datePrevue  DateTime? @map("date_prevue")
  dateRealisation DateTime? @map("date_realisation")
  fait        Boolean   @default(false) @map("fait")
  description String?   @map("description")
  cout        Float?    @map("cout") // €
  dureeMinutes Int?     @map("duree_minutes")
  nbPersonnes Int?      @default(1) @map("nb_personnes")
  produit     String?   @map("produit") // produit utilisé (engrais, traitement)
  quantite    Float?    @map("quantite")
  unite       String?   @map("unite")
  notes       String?   @map("notes")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([campagneId])
  @@index([type])
  @@index([fait])
  @@index([datePrevue])
  @@map("etapes_campagne")
}

/// Observations de suivi d'une campagne (taux de reprise, croissance)
model ObservationCampagne {
  id              Int       @id @default(autoincrement())
  userId          String    @map("user_id")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  campagneId      Int       @map("campagne_id")
  campagne        CampagnePlantation @relation(fields: [campagneId], references: [id], onDelete: Cascade)
  date            DateTime  @default(now()) @map("date")
  nbVivants       Int?      @map("nb_vivants")
  nbMorts         Int?      @map("nb_morts")
  nbManquants     Int?      @map("nb_manquants") // disparus / volés / mangés
  tauxReprise     Float?    @map("taux_reprise") // % calculé à la date
  hauteurMoyenneCm Float?   @map("hauteur_moyenne_cm")
  vigueur         String?   @map("vigueur") // "excellente", "bonne", "moyenne", "faible"
  problemes       String?   @map("problemes") // "gibier", "secheresse", "concurrence_herbeuse", "maladie"
  notes           String?   @map("notes")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([campagneId])
  @@index([date])
  @@map("observations_campagne")
}

// ============================================================
// ASSOCIATIONS DE PLANTES (COMPAGNONNAGE)
// ============================================================

/// Associations de plantes (compagnonnage)
model Association {
  id          String  @id // Ex: "asso-tomate-basilic"
  nom         String  // Ex: "Tomates-Basilic"
  description String?
  notes       String?

  // Relations
  details AssociationDetail[]

  @@map("associations")
}

/// Détails des associations (espèces/familles associées)
model AssociationDetail {
  id            Int          @id @default(autoincrement())
  associationId String       @map("association_id")
  association   Association  @relation(fields: [associationId], references: [id], onDelete: Cascade)
  especeId      String?      @map("espece")
  espece        Espece?      @relation(fields: [especeId], references: [id], onDelete: SetNull)
  familleId     String?      @map("famille")
  famille       Famille?     @relation(fields: [familleId], references: [id], onDelete: SetNull)
  groupe        String?      @map("groupe") // Groupe libre (ex: "Liliacées")
  requise       Boolean      @default(false) @map("requise") // Association requise ou bénéfique
  notes         String?      @map("notes")

  @@index([associationId])
  @@map("associations_details")
}

// ============================================================
// MODULE ÉLEVAGE - GESTION DES ANIMAUX
// ============================================================

/// Espèces animales (référentiel)
model EspeceAnimale {
  id                String    @id @map("espece_animale") // Ex: "poule_pondeuse", "lapin_chair"
  nom               String    @map("nom") // Nom d'affichage
  type              String    @map("type") // "volaille", "mammifere_petit", "mammifere_grand"
  production        String    @map("production") // "oeufs", "viande", "lait", "laine", "mixte"
  dureeGestation    Int?      @map("duree_gestation") // Jours (mammifères)
  dureeCouvaison    Int?      @map("duree_couvaison") // Jours (volailles)
  dureeElevage      Int?      @map("duree_elevage") // Jours jusqu'à maturité/abattage
  poidsAdulte       Float?    @map("poids_adulte") // kg
  rendementCarcasse Float?    @map("rendement_carcasse") // % du poids vif
  ponteAnnuelle     Int?      @map("ponte_annuelle") // Nombre d'œufs/an (pondeuses)
  consommationJour  Float?    @map("conso_jour") // kg aliment/jour
  prixAchat         Float?    @map("prix_achat") // Prix moyen d'achat €
  couleur           String?   @map("couleur") // Couleur UI
  description       String?   @map("description")

  // Relations
  animaux     Animal[]
  lots        LotAnimaux[]

  @@map("especes_animales")
}

/// Aliments pour animaux (similaire à Fertilisant)
model Aliment {
  id            String       @id @map("aliment") // Ex: "granules_pondeuses", "foin"
  nom           String       @map("nom")
  type          String?      @map("type") // "granules", "cereales", "foin", "complement"
  especesCibles String?      @map("especes_cibles") // CSV: "volaille,lapin"
  proteines     Float?       @map("proteines") // % protéines
  energie       Float?       @map("energie") // kcal/kg
  prix          Float?       @map("prix") // €/kg
  stock         Float?       @map("stock") // kg en stock
  dateStock     DateTime?    @map("date_stock")
  stockMin      Float?       @map("stock_min") // Seuil alerte
  fournisseurId String?      @map("fournisseur")
  fournisseur   Fournisseur? @relation(fields: [fournisseurId], references: [id], onDelete: SetNull)
  description   String?      @map("description")

  // Relations
  consommations ConsommationAliment[]
  userStocks    UserStockAliment[]

  @@map("aliments")
}

/// Animaux individuels
model Animal {
  id              Int            @id @default(autoincrement())
  userId          String         @map("user_id")
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  especeAnimaleId String         @map("espece_animale_id")
  especeAnimale   EspeceAnimale  @relation(fields: [especeAnimaleId], references: [id], onDelete: Restrict)
  lotId           Int?           @map("lot_id") // Appartenance à un lot (optionnel)
  lot             LotAnimaux?    @relation(fields: [lotId], references: [id], onDelete: SetNull)
  identifiant     String?        @map("identifiant") // Bague, boucle, puce
  nom             String?        @map("nom")
  race            String?        @map("race") // Race/variété
  sexe            String?        @map("sexe") // "male", "femelle", "inconnu"
  dateNaissance   DateTime?      @map("date_naissance")
  dateArrivee     DateTime?      @map("date_arrivee")
  provenance      String?        @map("provenance") // Éleveur, couvoir, etc.
  prixAchat       Float?         @map("prix_achat")
  statut          String         @default("actif") @map("statut") // "actif", "vendu", "abattu", "mort"
  dateSortie      DateTime?      @map("date_sortie") // Date vente/abattage/mort
  causeSortie     String?        @map("cause_sortie") // Raison de sortie
  // Position sur le plan (optionnel)
  posX            Float?         @map("pos_x")
  posY            Float?         @map("pos_y")
  // Généalogie
  mereId          Int?           @map("mere_id")
  mere            Animal?        @relation("ParentEnfant", fields: [mereId], references: [id], onDelete: SetNull)
  enfants         Animal[]       @relation("ParentEnfant")
  pereIdentifiant String?        @map("pere_identifiant") // Référence texte si père externe
  // Infos complémentaires
  poidsActuel     Float?         @map("poids_actuel") // kg
  couleur         String?        @map("couleur_robe") // Couleur de l'animal
  notes           String?        @map("notes")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  // Relations
  productionsOeufs ProductionOeuf[]
  soins            SoinAnimal[]
  abattages        Abattage[]
  naissancesMere   NaissanceAnimale[] @relation("NaissanceMere")
  // PROMPT 17 — collectes individuelles
  collectesLait    CollecteLait[]

  @@index([userId])
  @@index([especeAnimaleId])
  @@index([statut])
  @@index([lotId])
  @@index([mereId])
  @@map("animaux")
}

/// Lots d'animaux (gestion par groupe, surtout volailles)
model LotAnimaux {
  id                Int           @id @default(autoincrement())
  userId            String        @map("user_id")
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  especeAnimaleId   String        @map("espece_animale_id")
  especeAnimale     EspeceAnimale @relation(fields: [especeAnimaleId], references: [id], onDelete: Restrict)
  nom               String?       @map("nom") // Ex: "Lot pondeuses 2024"
  dateArrivee       DateTime?     @map("date_arrivee")
  quantiteInitiale  Int           @map("quantite_initiale")
  quantiteActuelle  Int           @map("quantite_actuelle")
  provenance        String?       @map("provenance")
  prixAchatTotal    Float?        @map("prix_achat_total")
  statut            String        @default("actif") @map("statut") // "actif", "reforme", "termine"
  dateReforme       DateTime?     @map("date_reforme")
  notes             String?       @map("notes")
  parcelleGeoId     String?       @map("parcelle_geo_id")
  parcelleGeo       ParcelleGeo?  @relation(fields: [parcelleGeoId], references: [id], onDelete: SetNull)
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  // Relations
  animaux          Animal[]
  productionsOeufs ProductionOeuf[]
  soins            SoinAnimal[]
  abattages        Abattage[]
  consommations    ConsommationAliment[]
  // PROMPT 17 — collectes par lot (volaille de chair vs caprin individuel)
  collectesLait    CollecteLait[]

  @@index([userId])
  @@index([especeAnimaleId])
  @@index([statut])
  @@map("lots_animaux")
}

/// Production d'œufs (quotidienne)
model ProductionOeuf {
  id         Int         @id @default(autoincrement())
  userId     String      @map("user_id")
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  lotId      Int?        @map("lot_id")
  lot        LotAnimaux? @relation(fields: [lotId], references: [id], onDelete: SetNull)
  animalId   Int?        @map("animal_id") // Si suivi individuel
  animal     Animal?     @relation(fields: [animalId], references: [id], onDelete: SetNull)
  date       DateTime    @default(now()) @map("date")
  quantite   Int         @map("quantite") // Nombre d'œufs
  casses     Int?        @default(0) @map("casses")
  sales      Int?        @default(0) @map("sales") // Œufs sales
  calibre    String?     @map("calibre") // "petit", "moyen", "gros", "tres_gros"
  notes      String?     @map("notes")
  createdAt  DateTime    @default(now()) @map("created_at")

  @@index([userId])
  @@index([lotId])
  @@index([animalId])
  @@index([date])
  @@map("production_oeufs")
}

/// Ventes de produits (œufs, viande, animaux vivants)
model VenteProduit {
  id            Int          @id @default(autoincrement())
  userId        String       @map("user_id")
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  date          DateTime     @default(now()) @map("date")
  type          String       @map("type") // "oeufs", "viande", "animal_vivant", "lait", "autre"
  description   String?      @map("description") // Ex: "Poulet fermier", "Œufs plein air"
  quantite      Float        @map("quantite")
  unite         String       @map("unite") // "unite", "douzaine", "kg", "L"
  prixUnitaire  Float        @map("prix_unitaire")
  prixTotal     Float        @map("prix_total")
  client        String?      @map("client") // Nom du client
  destinationId String?      @map("destination")
  destination   Destination? @relation(fields: [destinationId], references: [id], onDelete: SetNull)
  factureId     Int?         @map("facture_id")
  facture       Facture?     @relation("VenteProduitFacture", fields: [factureId], references: [id])
  paye          Boolean      @default(true) @map("paye")
  annule        Boolean      @default(false) @map("annule")
  dateAnnulation DateTime?   @map("date_annulation")
  tauxTVA       Float        @default(5.5) @map("taux_tva")
  // PROMPT 17 — traçabilité fromage : lien vers lot de fabrication
  lotFromageId  String?      @map("lot_fromage_id")
  lotFromage    LotFromage?  @relation(fields: [lotFromageId], references: [id], onDelete: SetNull)
  notes         String?      @map("notes")
  createdAt     DateTime     @default(now()) @map("created_at")

  @@index([userId])
  @@index([type])
  @@index([date])
  @@index([factureId])
  @@index([lotFromageId])
  @@map("ventes_produits")
}

/// Abattages
model Abattage {
  id           Int         @id @default(autoincrement())
  userId       String      @map("user_id")
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  animalId     Int?        @map("animal_id")
  animal       Animal?     @relation(fields: [animalId], references: [id], onDelete: SetNull)
  lotId        Int?        @map("lot_id")
  lot          LotAnimaux? @relation(fields: [lotId], references: [id], onDelete: SetNull)
  date         DateTime    @default(now()) @map("date")
  quantite     Int         @default(1) @map("quantite") // Nombre d'animaux (si lot)
  poidsVif     Float?      @map("poids_vif") // kg total
  poidsCarcasse Float?     @map("poids_carcasse") // kg total
  destination  String      @map("destination") // "auto_consommation", "vente", "don"
  prixVente    Float?      @map("prix_vente") // € si vendu
  factureId    Int?        @map("facture_id")
  facture      Facture?    @relation("AbattageFacture", fields: [factureId], references: [id])
  lieu         String?     @map("lieu") // "ferme", "abattoir"
  annule       Boolean     @default(false) @map("annule")
  dateAnnulation DateTime? @map("date_annulation")
  notes        String?     @map("notes")
  createdAt    DateTime    @default(now()) @map("created_at")

  @@index([userId])
  @@index([date])
  @@index([factureId])
  @@map("abattages")
}

/// Consommation d'aliments
