# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# PROMPT 16 LOT A — uploads utilisateurs (photos produits, observations, arbres).
# Le dossier doit exister dans l'image Docker mais ses contenus ne doivent pas
# être commités (données user-specific).
/public/uploads/*
!/public/uploads/.gitkeep

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# Development notes (not for production)
AGENT_PROMPT.md
ANALYSIS.md
CLAUDE.md
CLAUDE.md.*

# Confidential
dl/
audit/
PROMPT_AI_ENRICHMENT.md

# Junk: artefacts de redirection shell ratés (ex: `> et)` au lieu de `| cat`)
et)

# AI / MCP (proprietary)
# Le dossier /src/components/chat/ est ignoré SAUF les stubs publics
# (ChatPanel.tsx, ChatBubble.tsx). Le vrai code de ces 2 composants
# reste sur le VPS via `git update-index --skip-worktree` — cf.
# docs/private-stubs.md.
/src/components/chat/*
!/src/components/chat/ChatPanel.tsx
!/src/components/chat/ChatBubble.tsx
/src/lib/chat/
/src/lib/ollama.ts
/src/app/api/chat/
/src/app/api/mcp/
/src/app/api/user/api-token/
/src/hooks/use-chat.ts
/mcp-server/

# Boutique en ligne (proprietary)
# Modèles Prisma laissés publics (la compta y fait référence), mais
# l'UI / l'API / les composants UI restent privés.
/src/app/boutique/
/src/components/boutique/
/src/app/api/boutique/

# Système de feedback (proprietary)
# Outil opérationnel propre à gleba.fr (campagnes emails, enquêtes de
# satisfaction, signalement de bugs). Non distribué aux instances
# auto-hébergées. Les modèles Prisma (BugReport, FeedbackToken,
# FeedbackResponse) et le schéma de validation restent publics ; seuls
# l'UI, les routes, les scripts de campagne et les templates d'emails sont
# privés. Le composant FeedbackWidget garde un STUB public (cf.
# docs/private-stubs.md), le vrai code reste sur le VPS via skip-worktree.
/src/app/feedback/
/src/app/admin/feedback/
/src/app/api/feedback/
/src/app/api/admin/feedback/
/src/lib/mail-feedback.ts
/scripts/send-feedback-campaign.ts
/scripts/send-feedback-invite.ts
/scripts/generate-feedback-tokens.ts
/docs/implementation-artifacts/tech-spec-feedback-widget.md
